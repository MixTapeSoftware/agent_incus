#!/bin/bash
set -euo pipefail

# init-incus-claude
# Creates an Incus container with Claude Code and a mounted workspace.
#
# Default image: Ubuntu 24.04. Override with --image.

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
log()  { echo -e "${GREEN}[+]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
error(){ echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat << EOF
Usage: $(basename "$0") [OPTIONS] <container-name>

Create an Incus container with a mounted workspace.
Default image is Ubuntu 24.04. Shows an interactive TUI to select plugins.

Options:
  -p, --path PATH           Host directory to mount (default: current directory)
  -m, --mount-path PATH     Container mount point (default: /workspace)
  -f, --from TEMPLATE       Launch from a saved template (shorthand for --image incus-init/TEMPLATE)
  -i, --image IMAGE         Base image override (default: ubuntu/24.04)
  -t, --template            Save container as a reusable local template (implies --no-mount)
  --colima-cpus N           Colima VM CPUs (default: 4, macOS only)
  --colima-memory N         Colima VM memory in GB (default: 8, macOS only)
  --colima-disk N           Colima VM disk in GB (default: 100, macOS only)
  --no-mount                Clone repo into container instead of mounting host directory
  --ack-env                 Acknowledge .env files in the workspace (skip prompt)
  --no-sudo                 Do not grant sudo to the container user (for AI agents)
  --no-tui                  Skip interactive plugin selector, use defaults
  --dry-run                 Show what would be done without doing it
  -h, --help                Show this help

Plugins are defined in the plugins/ directory (or ~/.local/share/agent_incus/plugins/
for user plugins). Some provide CLI flags
(e.g. --1pass, --gh-token, --entire) to pre-select them without the TUI.
Drop a new .sh file in plugins/ (or ~/.local/share/agent_incus/plugins/) to add your own.
EOF
  exit 1
}

# ---------------------------------------------------------------------------
# Packages — grouped by purpose for readability
# ---------------------------------------------------------------------------

# --- Ubuntu/Debian (apt) ---
APT_CORE="bash curl git wget sudo unzip tmux zsh jq"
APT_BUILD="build-essential pkg-config autoconf automake bison cmake re2c"
APT_DEVLIBS="libssl-dev libncurses-dev libreadline-dev zlib1g-dev libbz2-dev libsqlite3-dev libffi-dev liblzma-dev libyaml-dev libxml2-dev libxslt1-dev libcurl4-openssl-dev libonig-dev libzip-dev libpng-dev libjpeg-dev libfreetype6-dev libgd-dev unixodbc-dev libpq-dev"
APT_RUNTIME="gpg ca-certificates psmisc fontconfig fzf bat inotify-tools python3 python3-dev python3-pip python3-venv nodejs npm postgresql-client default-mysql-client"

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------
require_commands() {
  local missing=()
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    error "Missing required commands: ${missing[*]}"
  fi
}

# ---------------------------------------------------------------------------
# Container readiness polling (replaces fragile sleep)
# ---------------------------------------------------------------------------
wait_for_container() {
  local name="$1" timeout="${2:-30}" elapsed=0
  local ready=0
  while [[ $elapsed -lt $timeout ]]; do
    if incus exec "$name" -- true >/dev/null 2>&1; then
      ready=1
      break
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  if [[ $ready -eq 0 ]]; then
    error "Container $name not ready after ${timeout}s"
  fi
  return 0
}

# Wait for networking inside the container (can lag behind boot/restart)
wait_for_network() {
  local name="$1" timeout="${2:-30}" elapsed=0
  log "Waiting for container networking..."
  local ready=0
  while [[ $elapsed -lt $timeout ]]; do
    if incus exec "$name" -- sh -c "getent hosts github.com >/dev/null 2>&1"; then
      ready=1
      break
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done
  if [[ $ready -eq 0 ]]; then
    error "Container $name has no network after ${timeout}s"
  fi
  return 0
}

# ---------------------------------------------------------------------------
# subuid / subgid helpers (internal plumbing for raw.idmap fallback)
# ---------------------------------------------------------------------------
id_in_subid_file() {
  local id=$1 file=$2
  [[ ! -f "$file" ]] && return 1
  while IFS=: read -r name start count || [[ -n "$name" ]]; do
    [[ -z "$name" || "$name" == \#* || "$name" != "root" ]] && continue
    local end=$((start + count - 1))
    [[ $id -ge $start && $id -le $end ]] && return 0
  done < "$file"
  return 1
}

entry_exists_in_file() {
  local entry=$1 file=$2
  [[ ! -f "$file" ]] && return 1
  grep -qxF "$entry" "$file" 2>/dev/null
}

ensure_subid_entries() {
  local uid="$1" gid="$2"
  local subuid_ok=0 subgid_ok=0

  id_in_subid_file "$uid" /etc/subuid && subuid_ok=1
  id_in_subid_file "$gid" /etc/subgid && subgid_ok=1

  [[ "$subuid_ok" == "1" && "$subgid_ok" == "1" ]] && return 0

  echo ""
  echo "Your UID/GID must be in /etc/subuid and /etc/subgid for write access."
  local entries=()
  [[ "$subuid_ok" == "0" ]] && ! entry_exists_in_file "root:$uid:1" /etc/subuid && \
    entries+=("/etc/subuid: root:$uid:1")
  [[ "$subgid_ok" == "0" ]] && ! entry_exists_in_file "root:$gid:1" /etc/subgid && \
    entries+=("/etc/subgid: root:$gid:1")

  [[ ${#entries[@]} -eq 0 ]] && return 0

  echo "Need to add (requires sudo):"
  printf '  %s\n' "${entries[@]}"
  read -rp "Add these entries? [Y/n] " reply
  [[ "$reply" =~ ^[Nn]$ ]] && return 1

  [[ "$subuid_ok" == "0" ]] && ! entry_exists_in_file "root:$uid:1" /etc/subuid && \
    echo "root:$uid:1" | sudo tee -a /etc/subuid > /dev/null
  [[ "$subgid_ok" == "0" ]] && ! entry_exists_in_file "root:$gid:1" /etc/subgid && \
    echo "root:$gid:1" | sudo tee -a /etc/subgid > /dev/null
}

# ---------------------------------------------------------------------------
# Mount workspace with user mapping
#
# Tries shift=true first (clean, kernel-level, no config needed).
# Falls back to raw.idmap (broader compat, needs subuid/subgid).
# If both fail, mounts without mapping (read-only for container user).
# ---------------------------------------------------------------------------
mount_workspace() {
  local container="$1" source="$2" target="$3" uid="$4" gid="$5"

  # Attempt 1: shift=true (kernel idmapped mounts, 5.12+)
  log "Trying shift=true mount..."
  if incus config device add "$container" workspace disk \
      source="$source" path="$target" shift=true 2>/dev/null; then
    log "Mounted with shift=true"
    return 0
  fi

  # shift failed, clean up
  incus config device remove "$container" workspace 2>/dev/null || true

  # Attempt 2: raw.idmap
  log "shift=true not supported, trying raw.idmap..."
  if ensure_subid_entries "$uid" "$gid"; then
    incus config device add "$container" workspace disk \
      source="$source" path="$target"
    incus config set "$container" raw.idmap="both $uid $uid"
    log "Restarting container for raw.idmap..."
    incus restart "$container"
    wait_for_container "$container"
    wait_for_network "$container"
    log "Mounted with raw.idmap"
    IDMAP_METHOD="raw"
    return 0
  fi

  # Attempt 3: no mapping
  warn "Could not configure user mapping. Mounting without write access."
  incus config device add "$container" workspace disk \
    source="$source" path="$target"
  IDMAP_METHOD="none"
  return 0
}

# ---------------------------------------------------------------------------
# Cleanup trap — offer to delete container on failure
# ---------------------------------------------------------------------------
cleanup_on_failure() {
  if [[ -n "${CONTAINER_NAME:-}" ]] && incus info "$CONTAINER_NAME" >/dev/null 2>&1; then
    echo ""
    warn "Script failed. Container '$CONTAINER_NAME' was partially created."
    read -rp "Delete it? [Y/n] " reply
    if [[ ! "$reply" =~ ^[Nn]$ ]]; then
      incus delete --force "$CONTAINER_NAME" 2>/dev/null || true
      log "Deleted $CONTAINER_NAME"
    else
      warn "Container left in place. Clean up manually with: incus delete --force $CONTAINER_NAME"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
WORKSPACE_PATH="$PWD"
MOUNT_PATH="/workspace"
BASE_IMAGE="images:ubuntu/24.04"
CONTAINER_NAME=""
DRY_RUN=0
NO_TUI=0
SAVE_TEMPLATE=0
NO_SUDO=0
NO_MOUNT=0
ACK_ENV=0
MAP_USER=0
IDMAP_METHOD=""

# ---------------------------------------------------------------------------
# Plugin discovery — reads built-in plugins/*.sh plus user plugins from
# ${XDG_DATA_HOME:-~/.local/share}/agent_incus/plugins/*.sh
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
BUILTIN_PLUGINS_DIR="$SCRIPT_DIR/plugins"
USER_PLUGINS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/agent_incus/plugins"

# Parallel arrays (bash 3.2 compatible — macOS /bin/bash has no associative arrays)
_P_ID=() _P_NAME=() _P_DESC=() _P_FILE=() _P_SELECTED=()
_P_FLAGS=() _P_FLAG_IDS=()   # parallel: _P_FLAGS[i] -> _P_FLAG_IDS[i]
PLUGIN_COUNT=0

# Find the slot index for a plugin ID; prints index or returns 1.
_plugin_slot() {
  local target="$1" i
  for ((i=0; i<PLUGIN_COUNT; i++)); do
    [[ "${_P_ID[$i]}" == "$target" ]] && { echo "$i"; return 0; }
  done
  return 1
}

selected_get() {
  local slot
  slot=$(_plugin_slot "$1") || { echo 0; return; }
  echo "${_P_SELECTED[$slot]:-0}"
}

selected_set() {
  local slot
  slot=$(_plugin_slot "$1") || return 1
  _P_SELECTED[$slot]="$2"
}

flag_to_id() {
  local target="$1" i
  for ((i=0; i<${#_P_FLAGS[@]}; i++)); do
    [[ "${_P_FLAGS[$i]}" == "$target" ]] && { echo "${_P_FLAG_IDS[$i]}"; return 0; }
  done
  return 1
}

# Discover built-in plugins first, then user plugins. On PLUGIN_ID collision
# the user plugin overrides (logged). Final order is sorted A-Z by PLUGIN_NAME
# below — drives both TUI display and install order.
for _dir in "$BUILTIN_PLUGINS_DIR" "$USER_PLUGINS_DIR"; do
  [[ -d "$_dir" ]] || continue
  for _f in "$_dir"/*.sh; do
    [[ -f "$_f" ]] || continue
    _meta=$(bash -c '
      PLUGIN_ID="" PLUGIN_NAME="" PLUGIN_DESC="" PLUGIN_DEFAULT=0
      PLUGIN_CLI_FLAGS="" PLUGIN_NEEDS_PROMPT=0 PLUGIN_RUN_ON_LAUNCH=0
      source "$1" 2>/dev/null
      printf "%s\n%s\n%s\n%s\n%s\n%s\n%s\n" \
        "$PLUGIN_ID" "$PLUGIN_NAME" "$PLUGIN_DESC" "$PLUGIN_DEFAULT" \
        "$PLUGIN_CLI_FLAGS" "$PLUGIN_NEEDS_PROMPT" "$PLUGIN_RUN_ON_LAUNCH"
    ' _ "$_f")

    IFS=$'\n' read -d '' -r _pid _pname _pdesc _pdefault _pcli _pprompt _plaunch <<< "$_meta" || true
    [[ -z "$_pid" ]] && continue

    if _existing=$(_plugin_slot "$_pid"); then
      echo "[!] Plugin '$_pid' from $_f overrides ${_P_FILE[$_existing]}" >&2
      _P_NAME[$_existing]="$_pname"
      _P_DESC[$_existing]="$_pdesc"
      _P_FILE[$_existing]="$_f"
      _P_SELECTED[$_existing]="${_pdefault:-0}"
      for _flag in $_pcli; do
        _P_FLAGS+=("$_flag")
        _P_FLAG_IDS+=("$_pid")
      done
      continue
    fi

    _i=$PLUGIN_COUNT
    _P_ID[$_i]="$_pid"
    _P_NAME[$_i]="$_pname"
    _P_DESC[$_i]="$_pdesc"
    _P_FILE[$_i]="$_f"
    _P_SELECTED[$_i]="${_pdefault:-0}"

    for _flag in $_pcli; do
      _P_FLAGS+=("$_flag")
      _P_FLAG_IDS+=("$_pid")
    done

    PLUGIN_COUNT=$((_i + 1))
  done
done
unset _dir _f _meta _i _pid _pname _pdesc _pdefault _pcli _pprompt _plaunch _flag _existing

# Sort plugins by PLUGIN_NAME, case-insensitive A-Z (stable).
if (( PLUGIN_COUNT > 1 )); then
  _sort_lines=""
  for ((_i=0; _i<PLUGIN_COUNT; _i++)); do
    _sort_lines+="${_P_NAME[$_i]}"$'\t'"$_i"$'\n'
  done
  _new_ID=() _new_NAME=() _new_DESC=() _new_FILE=() _new_SELECTED=()
  while IFS=$'\t' read -r _name _slot; do
    _new_ID+=("${_P_ID[$_slot]}")
    _new_NAME+=("${_P_NAME[$_slot]}")
    _new_DESC+=("${_P_DESC[$_slot]}")
    _new_FILE+=("${_P_FILE[$_slot]}")
    _new_SELECTED+=("${_P_SELECTED[$_slot]}")
  done < <(printf '%s' "$_sort_lines" | sort -f -s -t$'\t' -k1,1)
  _P_ID=("${_new_ID[@]}")
  _P_NAME=("${_new_NAME[@]}")
  _P_DESC=("${_new_DESC[@]}")
  _P_FILE=("${_new_FILE[@]}")
  _P_SELECTED=("${_new_SELECTED[@]}")
  unset _new_ID _new_NAME _new_DESC _new_FILE _new_SELECTED _sort_lines _name _slot _i
fi

# Build the PLUGINS array the TUI expects (id:name:desc:default)
PLUGINS=()
for ((_i=0; _i<PLUGIN_COUNT; _i++)); do
  PLUGINS+=("${_P_ID[$_i]}:${_P_NAME[$_i]}:${_P_DESC[$_i]}:${_P_SELECTED[$_i]}")
done
unset _i

# ---------------------------------------------------------------------------
# TUI plugin selector
# ---------------------------------------------------------------------------
show_tui() {
  local count=${#PLUGINS[@]}
  local cursor=0
  local key seq marker id name desc default

  tput civis 2>/dev/null || true
  trap 'tput cnorm 2>/dev/null || true' RETURN

  while true; do
    printf '\033[2J\033[H'
    echo -e "${GREEN}+------------------------------------------------------+${NC}"
    echo -e "${GREEN}|${NC}  Select plugins to install                           ${GREEN}|${NC}"
    echo -e "${GREEN}+------------------------------------------------------+${NC}"
    echo -e "${GREEN}|${NC}  Up/Down or j/k: navigate   Space: toggle   Enter: go${GREEN}|${NC}"
    echo -e "${GREEN}|${NC}  q: quit                                             ${GREEN}|${NC}"
    echo -e "${GREEN}+------------------------------------------------------+${NC}"
    echo ""

    for ((i=0; i<count; i++)); do
      IFS=: read -r id name desc default <<< "${PLUGINS[$i]}"
      marker="[ ]"
      [[ "${_P_SELECTED[$i]}" == "1" ]] && marker="[x]"

      if [[ $i -eq $cursor ]]; then
        printf "  \033[7m %s %-24s %s \033[0m\n" "$marker" "$name" "$desc"
      else
        printf "   %s %-24s %s\n" "$marker" "$name" "$desc"
      fi
    done

    echo ""

    IFS= read -rsn1 key

    case "$key" in
      $'\x1b')
        IFS= read -rsn2 -t 1 seq || continue
        case "$seq" in
          '[A') cursor=$(( (cursor - 1 + count) % count )) ;;
          '[B') cursor=$(( (cursor + 1) % count )) ;;
        esac
        ;;
      'k') cursor=$(( (cursor - 1 + count) % count )) ;;
      'j') cursor=$(( (cursor + 1) % count )) ;;
      ' ')
        if [[ "${_P_SELECTED[$cursor]}" == "1" ]]; then
          _P_SELECTED[$cursor]=0
        else
          _P_SELECTED[$cursor]=1
        fi
        ;;
      ''|$'\n') break ;;
      'q')
        tput cnorm 2>/dev/null || true
        echo "Aborted."
        exit 1
        ;;
    esac
  done

  tput cnorm 2>/dev/null || true
  printf '\033[2J\033[H'
}

# ---------------------------------------------------------------------------
# Core install functions (not plugins)
# ---------------------------------------------------------------------------
install_ohmyzsh() {
  log "Installing Oh My Zsh..."
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'bash -s' <<'ZSHEOF'
  set -e
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

  sed -i 's/^ZSH_THEME=".*"/ZSH_THEME="dpoggi"/' ~/.zshrc

  # Add [incus] prefix to prompt
  cat >> ~/.zshrc <<'RCBLOCK'

# [incus] prompt prefix
PROMPT="%{$fg[cyan]%}[incus]%{$reset_color%} ${PROMPT%»*}%{$reset_color%}"$'\n'"» "
RCBLOCK

  # Plugins
  git clone https://github.com/zsh-users/zsh-autosuggestions \
    ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions
  sed -i 's/^plugins=(git)/plugins=(git zsh-autosuggestions)/' ~/.zshrc
ZSHEOF
}


# ---------------------------------------------------------------------------
# Component dispatch helpers
# ---------------------------------------------------------------------------
# Source a plugin file and call its functions. We iterate _P_FILE
# (sorted A-Z by PLUGIN_NAME during discovery) so install order matches the
# TUI display order and is identical across hosts.
#
# Sourced plugin files do not overwrite metadata vars or functions they don't
# declare, so without an explicit reset, values leak from one plugin to the
# next (e.g. PLUGIN_NEEDS_PROMPT=1 and plugin_prompt from 1pass would carry
# over to a later plugin that selected without one).
_reset_plugin_state() {
  PLUGIN_ID="" PLUGIN_NAME="" PLUGIN_DESC="" PLUGIN_DEFAULT=0
  PLUGIN_CLI_FLAGS="" PLUGIN_NEEDS_PROMPT=0 PLUGIN_RUN_ON_LAUNCH=0
  unset -f plugin_prompt plugin_is_installed plugin_install plugin_on_launch 2>/dev/null || true
}

_run_plugin_prompts() {
  local i
  for ((i=0; i<PLUGIN_COUNT; i++)); do
    _reset_plugin_state
    source "${_P_FILE[$i]}"
    [[ "$(selected_get "$PLUGIN_ID")" != "1" ]] && continue
    [[ "${PLUGIN_NEEDS_PROMPT:-0}" != "1" ]] && continue
    plugin_prompt
  done
}

_run_plugin_installs() {
  local from_template="$1"
  local i
  for ((i=0; i<PLUGIN_COUNT; i++)); do
    _reset_plugin_state
    source "${_P_FILE[$i]}"
    [[ "$(selected_get "$PLUGIN_ID")" != "1" ]] && continue

    if [[ "$from_template" == "1" ]]; then
      # Template launch dispatch:
      #   not installed                     -> plugin_install (added on top of template)
      #   installed + NEEDS_PROMPT=1        -> plugin_install (re-apply prompted token/config)
      #   installed + RUN_ON_LAUNCH=1       -> plugin_on_launch (symlinks/config hooks)
      #   otherwise                         -> skip (already baked in)
      local _installed=0
      if declare -F plugin_is_installed >/dev/null && plugin_is_installed; then
        _installed=1
      fi
      if [[ "$_installed" == "0" ]]; then
        plugin_install
      elif [[ "${PLUGIN_NEEDS_PROMPT:-0}" == "1" ]]; then
        plugin_install
      elif [[ "${PLUGIN_RUN_ON_LAUNCH:-0}" == "1" ]] && declare -F plugin_on_launch >/dev/null; then
        plugin_on_launch
      fi
    else
      # Fresh install
      if declare -F plugin_is_installed >/dev/null && plugin_is_installed; then
        log "$PLUGIN_NAME already installed, skipping"
        continue
      fi
      plugin_install
    fi
  done
}

save_template() {
  local alias="incus-init/$CONTAINER_NAME"
  log "Saving as local template: $alias (stored in local Incus image store)"

  # Save token lines from .zshenv, then strip them so they don't leak into the image
  local saved_tokens
  saved_tokens=$(incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c \
    "grep -E '^export (GH_TOKEN|OP_SERVICE_ACCOUNT_TOKEN)=' ~/.zshenv 2>/dev/null || true")

  log "Scrubbing secrets from image..."
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c \
    "sed -i '/^export OP_SERVICE_ACCOUNT_TOKEN=/d; /^export GH_TOKEN=/d' ~/.zshenv 2>/dev/null || true"

  log "Stopping container for snapshot..."
  incus stop "$CONTAINER_NAME"
  incus publish "$CONTAINER_NAME" --alias "$alias"
  log "Starting container back up..."
  incus start "$CONTAINER_NAME"
  wait_for_container "$CONTAINER_NAME"

  # Restore saved tokens to the running container
  if [[ -n "$saved_tokens" ]]; then
    incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c "cat >> ~/.zshenv <<'TOKENS'
$saved_tokens
TOKENS"
  fi

  wait_for_network "$CONTAINER_NAME"
  log "Saved template: $alias"
  echo "  Reuse with: $(basename "$0") --from $CONTAINER_NAME <new-name>"
}

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--path)       [[ $# -lt 2 ]] && error "$1 requires an argument"; WORKSPACE_PATH="$2"; shift 2 ;;
    -m|--mount-path) [[ $# -lt 2 ]] && error "$1 requires an argument"; MOUNT_PATH="$2"; shift 2 ;;
    -f|--from)       [[ $# -lt 2 ]] && error "$1 requires an argument"; BASE_IMAGE="incus-init/$2"; shift 2 ;;
    -i|--image)      [[ $# -lt 2 ]] && error "$1 requires an argument"; BASE_IMAGE="$2"; shift 2 ;;
    -t|--template) SAVE_TEMPLATE=1; shift ;;
    --colima-cpus)   [[ $# -lt 2 ]] && error "$1 requires an argument"; COLIMA_CPUS="$2"; shift 2 ;;
    --colima-memory) [[ $# -lt 2 ]] && error "$1 requires an argument"; COLIMA_MEMORY="$2"; shift 2 ;;
    --colima-disk)   [[ $# -lt 2 ]] && error "$1 requires an argument"; COLIMA_DISK="$2"; shift 2 ;;
    --no-mount)      NO_MOUNT=1; shift ;;
    --ack-env)       ACK_ENV=1; shift ;;
    --no-sudo)       NO_SUDO=1; shift ;;
    --no-tui)        NO_TUI=1; shift ;;
    --dry-run)       DRY_RUN=1; shift ;;
    -h|--help)       usage ;;
    -*)
      # Check if it's a plugin CLI flag
      if _flag_id=$(flag_to_id "$1"); then
        selected_set "$_flag_id" 1
        shift
      else
        error "Unknown option: $1"
      fi
      ;;
    *)               CONTAINER_NAME="$1"; shift ;;
  esac
done

# ---------------------------------------------------------------------------
# macOS pre-flight (noop on Linux)
# ---------------------------------------------------------------------------
source "$SCRIPT_DIR/incus.macos.setup"
source "$SCRIPT_DIR/incus.envscan"

# ---------------------------------------------------------------------------
# Validate
# ---------------------------------------------------------------------------
require_commands incus curl sudo realpath

[[ -z "$CONTAINER_NAME" ]] && { warn "Container name required"; echo ""; usage; }
[[ ! "$CONTAINER_NAME" =~ ^[a-zA-Z][a-zA-Z0-9-]*$ ]] && error "Invalid container name: must start with a letter, only letters/digits/hyphens"
incus info "$CONTAINER_NAME" >/dev/null 2>&1 && error "Container '$CONTAINER_NAME' already exists"

if [[ "$NO_MOUNT" == "0" ]]; then
  WORKSPACE_PATH="${WORKSPACE_PATH/#\~/$HOME}"
  WORKSPACE_PATH="$(realpath "$WORKSPACE_PATH")"
  [[ ! -d "$WORKSPACE_PATH" ]] && error "Directory not found: $WORKSPACE_PATH"
fi

if [[ "$SAVE_TEMPLATE" == "1" ]]; then
  NO_MOUNT=1
fi

# ---------------------------------------------------------------------------
# .env warning — only when actually mounting the host workspace
# ---------------------------------------------------------------------------
ENV_FILES_LIST=""
if [[ "$NO_MOUNT" == "0" ]]; then
  ENV_FILES_LIST="$(detect_env_files "$WORKSPACE_PATH")"
  if [[ -n "$ENV_FILES_LIST" ]]; then
    echo ""
    while IFS= read -r _line; do
      echo -e "${YELLOW}${_line}${NC}" >&2
    done < <(printf '%s\n' "$ENV_FILES_LIST" | format_env_warning_lines "$WORKSPACE_PATH")
    confirm_env_acknowledgement "$ACK_ENV"
  fi
fi

HOST_USER="$(whoami)"
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"

# ---------------------------------------------------------------------------
# User mapping prompt — simple yes/no, implementation details are hidden
# ---------------------------------------------------------------------------
echo ""
read -rp "Map host user into container for workspace write access? [Y/n] " MAP_CHOICE
if [[ ! "${MAP_CHOICE:-Y}" =~ ^[Nn]$ ]]; then
  MAP_USER=1
fi

# ---------------------------------------------------------------------------
# TUI plugin selector
# ---------------------------------------------------------------------------
if [[ "$NO_TUI" == "0" ]]; then
  show_tui
fi

# ---------------------------------------------------------------------------
# Component prompts — called once, after TUI decision
# ---------------------------------------------------------------------------
_run_plugin_prompts

# ---------------------------------------------------------------------------
# Dry-run summary
# ---------------------------------------------------------------------------
if [[ "$DRY_RUN" == "1" ]]; then
  echo ""
  echo "========================================"
  echo "DRY RUN — nothing will be created"
  echo "========================================"
  echo "Container:   $CONTAINER_NAME"
  echo "Image:       $BASE_IMAGE"
  echo "User:        $HOST_USER (UID:$HOST_UID GID:$HOST_GID)"
  if [[ "$NO_MOUNT" == "1" ]]; then
    echo "Workspace:   git clone into $MOUNT_PATH (no host mount)"
  else
    echo "Workspace:   $WORKSPACE_PATH -> $MOUNT_PATH"
  fi
  if [[ -n "$ENV_FILES_LIST" ]]; then
    _env_count="$(printf '%s\n' "$ENV_FILES_LIST" | wc -l | tr -d ' ')"
    echo ".env files exposed: $_env_count"
    _shown=0
    while IFS= read -r _envpath; do
      if (( _shown >= 20 )); then
        echo "  …and $(( _env_count - 20 )) more"
        break
      fi
      echo "  ${_envpath#$WORKSPACE_PATH/}"
      _shown=$(( _shown + 1 ))
    done <<< "$ENV_FILES_LIST"
  fi
  echo "Write access: $( [[ "$MAP_USER" == "1" ]] && echo "yes (auto-detect method)" || echo "no" )"
  echo ""
  echo "Selected plugins:"
  for entry in "${PLUGINS[@]}"; do
    IFS=: read -r id name desc default <<< "$entry"
    if [[ "$(selected_get "$id")" == "1" ]]; then
      echo "  [x] $name"
    else
      echo "  [ ] $name"
    fi
  done
  echo ""
  echo "Template:    $( [[ "$SAVE_TEMPLATE" == "1" ]] && echo "incus-init/$CONTAINER_NAME" || echo no )"
  echo "========================================"
  exit 0
fi

# ---------------------------------------------------------------------------
# From here on, real work — set up cleanup trap
# ---------------------------------------------------------------------------
trap cleanup_on_failure ERR

# ---------------------------------------------------------------------------
# Detect if launching from a local base image (skip provisioning)
# ---------------------------------------------------------------------------
FROM_BASE_IMAGE=0
if [[ "$BASE_IMAGE" != images:* ]]; then
  FROM_BASE_IMAGE=1
  if ! incus image info "$BASE_IMAGE" &>/dev/null; then
    error "Template image '$BASE_IMAGE' not found. Run 'incus image list' to see available templates."
  fi
  log "Using local template: $BASE_IMAGE"
fi

# ---------------------------------------------------------------------------
# Create container
# ---------------------------------------------------------------------------
log "Creating container: $CONTAINER_NAME ($(basename "$BASE_IMAGE"))"
incus launch "$BASE_IMAGE" "$CONTAINER_NAME"
incus config set "$CONTAINER_NAME" user.managed-by=agent-incus

wait_for_container "$CONTAINER_NAME"
wait_for_network "$CONTAINER_NAME"

# ---------------------------------------------------------------------------
# Provision (skipped when launching from a local base image)
# ---------------------------------------------------------------------------
if [[ "$FROM_BASE_IMAGE" == "0" ]]; then

  # --- Install packages ---
  log "Installing packages..."
  incus exec "$CONTAINER_NAME" -- sh -es <<PACKAGES
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y
    apt-get install -y $APT_CORE $APT_BUILD $APT_DEVLIBS $APT_RUNTIME
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # Extra repos (mise + GitHub CLI)
    install -dm 755 /etc/apt/keyrings
    curl -fsSL https://mise.jdx.dev/gpg-key.pub | gpg --dearmor -o /etc/apt/keyrings/mise-archive-keyring.gpg
    echo "deb [signed-by=/etc/apt/keyrings/mise-archive-keyring.gpg] https://mise.jdx.dev/deb stable main" | tee /etc/apt/sources.list.d/mise.list
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg 2>/dev/null
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=\$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list
    apt-get update -y
    apt-get install -y mise gh
PACKAGES

fi  # end FROM_BASE_IMAGE == 0

# ---------------------------------------------------------------------------
# Create user (always — base image may have been built by a different user)
# ---------------------------------------------------------------------------
log "Creating user $HOST_USER..."
incus exec "$CONTAINER_NAME" -- sh -c "
  # Skip creation if user already exists with correct UID
  if ! (id $HOST_USER >/dev/null 2>&1 && [ \"\$(id -u $HOST_USER)\" = \"$HOST_UID\" ]); then
    ZSH_PATH=\$(command -v zsh || echo /bin/bash)

    # Remove conflicting UID/GID owners
    EXISTING_USER=\$(getent passwd $HOST_UID | cut -d: -f1 || true)
    EXISTING_GROUP=\$(getent group $HOST_GID | cut -d: -f1 || true)

    if [ -n \"\$EXISTING_USER\" ] && [ \"\$EXISTING_USER\" != \"$HOST_USER\" ]; then
      userdel -r \"\$EXISTING_USER\" 2>/dev/null || userdel \"\$EXISTING_USER\" 2>/dev/null || true
    fi
    if [ -n \"\$EXISTING_GROUP\" ] && [ \"\$EXISTING_GROUP\" != \"$HOST_USER\" ]; then
      groupdel \"\$EXISTING_GROUP\" 2>/dev/null || true
    fi

    groupadd -g $HOST_GID $HOST_USER 2>/dev/null || true
    useradd -m -u $HOST_UID -g $HOST_GID -s \"\$ZSH_PATH\" $HOST_USER || exit 1
  fi

  id $HOST_USER >/dev/null 2>&1 || { echo 'User creation failed' >&2; exit 1; }

  # Sudo: always enforce current flag state (base image may differ)
  if [ \"$NO_SUDO\" = \"1\" ]; then
    rm -f /etc/sudoers.d/$HOST_USER
  else
    echo '$HOST_USER ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/$HOST_USER
    chmod 0440 /etc/sudoers.d/$HOST_USER
  fi
"

# ---------------------------------------------------------------------------
# Disable mise's gix-based git cloner. gix trips on some asdf plugin repos
# (notably asdf-php) with "Failed to update references to their new position
# to match their remote locations" and fails any mise install run by the
# user later. System git handles the same clones fine.
# ---------------------------------------------------------------------------
log "Configuring mise to use system git (gix=false)..."
incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'bash -s' <<'MISECFG'
  set -e
  mkdir -p "$HOME/.config/mise"
  cfg="$HOME/.config/mise/config.toml"
  if [[ ! -f "$cfg" ]] || ! grep -q '^\[settings\]' "$cfg"; then
    printf '[settings]\ngix = false\n' >> "$cfg"
  elif ! grep -qE '^gix *= *false' "$cfg"; then
    # [settings] exists but no gix=false line — append under the section
    awk '
      /^\[settings\]/ { print; print "gix = false"; next }
      { print }
    ' "$cfg" > "$cfg.new" && mv "$cfg.new" "$cfg"
  fi
MISECFG

# ---------------------------------------------------------------------------
# Mount workspace or clone repo
# ---------------------------------------------------------------------------
if [[ "$NO_MOUNT" == "1" ]]; then
  # Check if mount path exists and has content (e.g. from a base image built without --no-mount)
  if incus exec "$CONTAINER_NAME" -- sh -c "[ -d '$MOUNT_PATH' ] && [ \"\$(ls -A '$MOUNT_PATH')\" ]"; then
    error "$MOUNT_PATH is not empty inside the container. Rebuild the base image with --no-mount."
  fi
  incus exec "$CONTAINER_NAME" -- sh -c \
    "mkdir -p $MOUNT_PATH && chown $HOST_USER:$HOST_USER $MOUNT_PATH"
  REPO_URL="$(git -C "$PWD" remote get-url origin 2>/dev/null || true)"
  if [[ -n "$REPO_URL" ]]; then
    REPO_BRANCH="$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    log "Cloning repo into container (--no-mount)..."
    incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c \
      "git clone --branch ${REPO_BRANCH:-main} $REPO_URL $MOUNT_PATH"
  else
    log "No git remote found — creating empty $MOUNT_PATH"
  fi
  IDMAP_METHOD="clone"
else
  log "Mounting workspace: $WORKSPACE_PATH -> $MOUNT_PATH"

  if [[ "$MAP_USER" == "1" ]]; then
    mount_workspace "$CONTAINER_NAME" "$WORKSPACE_PATH" "$MOUNT_PATH" "$HOST_UID" "$HOST_GID"
  else
    incus config device add "$CONTAINER_NAME" workspace disk \
      source="$WORKSPACE_PATH" path="$MOUNT_PATH"
    IDMAP_METHOD="none"
  fi
fi

# Final readiness check
wait_for_container "$CONTAINER_NAME"
incus exec "$CONTAINER_NAME" -- id "$HOST_USER" >/dev/null 2>&1 \
  || error "User $HOST_USER does not exist. User creation may have failed."

wait_for_network "$CONTAINER_NAME"

# ---------------------------------------------------------------------------
# Shell setup (skipped when launching from a local base image)
# ---------------------------------------------------------------------------
if [[ "$FROM_BASE_IMAGE" == "0" ]]; then

  log "Configuring zsh..."
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'bash -s' <<'ZSHEOF'
    set -e

    # Auto-cd to /workspace on login
    touch ~/.zshrc
    cat >> ~/.zprofile <<'WORKSPACE'
if [[ -d /workspace ]]; then
    cd /workspace
fi
WORKSPACE
ZSHEOF

  # Install Oh My Zsh — must run before appending to .zshrc since
  # the installer replaces .zshrc with its own template
  install_ohmyzsh

  # Append mise activation and PATH after Oh My Zsh has written its .zshrc
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'bash -s' <<'ZSHEOF'
    set -e
    echo 'eval "$(mise activate zsh)"' >> ~/.zshrc
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.zshrc
ZSHEOF

fi  # end FROM_BASE_IMAGE == 0

# ---------------------------------------------------------------------------
# Install selected plugins
# ---------------------------------------------------------------------------
_run_plugin_installs "$FROM_BASE_IMAGE"

# Run mise install if the workspace has a config
if [[ -f "$WORKSPACE_PATH/mise.toml" || -f "$WORKSPACE_PATH/.mise.toml" || -f "$WORKSPACE_PATH/.tool-versions" ]]; then
  log "Trusting workspace mise config..."
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'cd /workspace && mise trust'

  # Pre-clone asdf plugins with system git before `mise install`.
  # mise's built-in gix cloner trips on some plugin repos (e.g. asdf-php)
  # with "Failed to update references to their new position to match their
  # remote locations". `mise settings set gix false` does not reliably disable
  # gix in current mise releases, so we sidestep the clone entirely: if the
  # plugin dir already exists, mise skips its own clone.
  log "Pre-cloning mise plugins via system git (gix workaround)..."
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'bash -s' <<'PRECLONE'
    set -e
    tools=$(python3 - <<'PY'
import os, re
tools = set()
for f in ("mise.toml", ".mise.toml"):
    p = f"/workspace/{f}"
    if not os.path.exists(p):
        continue
    in_tools = False
    with open(p) as fh:
        for line in fh:
            s = line.strip()
            m = re.match(r'^\[([A-Za-z0-9_.-]+)\]', s)
            if m:
                sect = m.group(1)
                in_tools = (sect == "tools")
                if sect.startswith("tools."):
                    tools.add(sect[6:])
                continue
            if not in_tools or not s or s.startswith("#"):
                continue
            km = re.match(r'^"?([A-Za-z0-9_-]+)"?\s*=', s)
            if km:
                tools.add(km.group(1))
p = "/workspace/.tool-versions"
if os.path.exists(p):
    with open(p) as fh:
        for line in fh:
            s = line.strip()
            if s and not s.startswith("#"):
                tools.add(s.split()[0])
for t in sorted(tools):
    print(t)
PY
)
    # Tools mise ships as core/builtin plugins — no asdf clone needed.
    core="bun deno elixir erlang go golang java node nodejs python python3 ruby rust zig"
    plugins_dir="$HOME/.local/share/mise/plugins"
    mkdir -p "$plugins_dir"
    for tool in $tools; do
      case " $core " in *" $tool "*) continue ;; esac
      [[ -d "$plugins_dir/$tool" ]] && continue
      url="https://github.com/mise-plugins/asdf-$tool.git"
      if git clone --quiet --depth 1 "$url" "$plugins_dir/$tool" 2>/dev/null; then
        echo "  pre-cloned: $tool"
      else
        rm -rf "$plugins_dir/$tool"
        echo "  no asdf-$tool plugin on mise-plugins; letting mise resolve"
      fi
    done
PRECLONE

  log "Running mise install for workspace..."
  incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c 'cd /workspace && mise install'
fi

# Expose mise shims to non-interactive shells (e.g. Claude Code's Bash tool)
# by symlinking them into ~/.local/bin, which is on the default PATH.
# mise activation in .zshrc only covers interactive zsh; without this,
# `incus exec ... bash -c '...'` falls through to system binaries.
log "Syncing mise shims into ~/.local/bin..."
incus exec "$CONTAINER_NAME" -- su - "$HOST_USER" -c '
  shims="$HOME/.local/share/mise/shims"
  if [[ -d "$shims" ]]; then
    mkdir -p "$HOME/.local/bin"
    for shim in "$shims"/*; do
      [[ -e "$shim" ]] || continue
      ln -sf "$shim" "$HOME/.local/bin/$(basename "$shim")"
    done
  fi
'


# ---------------------------------------------------------------------------
# Disable cleanup trap on success
# ---------------------------------------------------------------------------
trap - ERR

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
log "Container ready!"
echo ""
echo "========================================"
echo "Container:   $CONTAINER_NAME"
echo "Image:       $BASE_IMAGE"
echo "User:        $HOST_USER (UID:$HOST_UID GID:$HOST_GID)"
if [[ "$NO_MOUNT" == "1" ]]; then
  echo "Workspace:   git clone into $MOUNT_PATH (no host mount)"
else
  echo "Workspace:   $WORKSPACE_PATH -> $MOUNT_PATH"
fi
echo "Write access: ${IDMAP_METHOD:-none}"
echo ""
echo "Installed:"
for entry in "${PLUGINS[@]}"; do
  IFS=: read -r id name desc default <<< "$entry"
  [[ "$(selected_get "$id")" == "1" ]] && echo "  ✓ $name"
done
echo "========================================"
echo ""
echo "Shell in:"
echo "  incs $CONTAINER_NAME"
echo ""
if [[ "$(selected_get claude-code)" == "1" ]]; then
echo "Start Claude Code:"
echo "  incs -s $CONTAINER_NAME 'cd $MOUNT_PATH && claude'"
fi

# ---------------------------------------------------------------------------
# Publish as local image (optional)
# ---------------------------------------------------------------------------
if [[ "$SAVE_TEMPLATE" == "1" ]]; then
  save_template
fi
