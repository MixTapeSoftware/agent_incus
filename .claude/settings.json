{
  "disableAllHooks": false,
  "env": {
    "CLAUDE_AUTO_APPROVE": "true",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "WebSearch",
      "NotebookEdit(**)",
      "SlashCommand(*)",
      "Skill(*)"
    ],
    "ask": ["WebFetch(*)"],
    "defaultMode": "acceptEdits",
    "deny": ["Read(./.entire/metadata/**)"]
  }
}
