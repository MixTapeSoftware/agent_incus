# incus.envscan
# Detect .env* files in the workspace about to be mounted, format a warning,
# and gate the launch on user acknowledgement.
#
# Sourced by incus.init — inherits colors, log/warn/error, set -euo pipefail.
# Defines functions only; no top-level work, so it is safe to source from
# tests without triggering side effects.

# ---------------------------------------------------------------------------
# detect_env_files DIR
#
# Print absolute paths of .env* files under DIR, one per line.
# Excludes:
#   - paths containing /node_modules/, /.git/, /vendor/, /target/, /dist/, /build/
#   - basenames .env.example, .env.sample, .env.template, .env.dist
# Output is empty (and exit 0) when nothing matches.
# ---------------------------------------------------------------------------
detect_env_files() {
  local dir="$1"
  find "$dir" \
    \( -type d \( \
        -name node_modules -o \
        -name .git        -o \
        -name vendor      -o \
        -name target      -o \
        -name dist        -o \
        -name build \
       \) -prune \) \
    -o \
    \( -type f -name '.env*' \
       ! -name '.env.example' \
       ! -name '.env.sample' \
       ! -name '.env.template' \
       ! -name '.env.dist' \
       -print \)
}

# ---------------------------------------------------------------------------
# format_env_warning_lines WORKSPACE_ROOT
#
# Reads absolute .env* paths from stdin (one per line), prints the warning
# block to stdout. Each line is prefixed with "[!] " so it composes cleanly
# with the existing warn() helper's marker convention.
#
# - Paths shown relative to WORKSPACE_ROOT
# - List truncated to 20 entries with "…and N more" line
# - Block text is verbatim from the spec; paths sorted alphabetically
# ---------------------------------------------------------------------------
format_env_warning_lines() {
  local workspace="$1"
  local -a paths=()
  local line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    paths+=("${line#$workspace/}")
  done

  # Sort paths alphabetically for predictable user output.
  if (( ${#paths[@]} > 0 )); then
    local IFS=$'\n'
    paths=( $(printf '%s\n' "${paths[@]}" | LC_ALL=C sort) )
    unset IFS
  fi

  local total=${#paths[@]}
  local shown=$total
  local remaining=0
  if (( total > 20 )); then
    shown=20
    remaining=$(( total - 20 ))
  fi

  printf '[!] The workspace mount will expose these .env files inside the container:\n'
  local i
  for (( i=0; i<shown; i++ )); do
    printf '[!]       %s\n' "${paths[$i]}"
  done
  if (( remaining > 0 )); then
    printf '[!]       …and %d more\n' "$remaining"
  fi
  printf '[!] Anything running in the container — including coding agents — can read these.\n'
  printf "[!] Adding a .env to the workspace later will also be visible; this warning only\n"
  printf "[!] reflects what's present right now.\n"
  printf '[!] Safer pattern: use the 1Password CLI to hydrate env at runtime\n'
  printf '[!] (`op run --env-file=.env.tpl -- ./your-cmd`) with op:// references in place of\n'
  printf '[!] plaintext secrets, and skip the 1pass plugin in agent containers so the agent\n'
  printf "[!] can't resolve those references.\n"
}
