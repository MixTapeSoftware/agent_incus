#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()   { echo -e "${GREEN}[+]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

INCS_STATE_DIR="$HOME/.local/state/incs"
INCS_LOG_DIR="${INCS_LOG_DIR:-$INCS_STATE_DIR/logs}"
INCS_STATUS_FILE="$INCS_STATE_DIR/last-update"

usage() {
  cat <<'EOF'
Usage: incs [command] [args...]

Commands:
  <container>                    Shell into container (default)
  -s, shell <container> [cmd]    Shell into container
  -i, init [args...]             Create/provision a new container
  -n, net <container> [ports...] Manage port proxies
  -e, env <container> <VAR>      Set env variable (prompts silently, paste-friendly)
  -d, delete <container>          Force delete a container
  -k, kill <container>           Stop a container
  -ka, kill-all                  Stop all agent-incus containers
  -u, update <container>         Update packages in a container
  -ua, update-all                Update packages in all agent-incus containers
  new-plugin <slug> [opts]       Generate a new plugin file from a template
  -h, help                       Show this help

Cron:
  cron install [HOUR]            Install nightly update cron (default: 19)
  cron remove                    Remove the update cron
  cron status                    Show current cron schedule

Examples:
  incs your-container                        Shell into your-container
  incs -s your-container                     Shell into your-container (explicit)
  incs -s your-container mix test            Run a command in your-container
  incs -i your-container --from base-dev     Init your-container from template
  incs -n your-container 4000 3241           Proxy ports 4000 and 3241
  incs -n your-container 4000:8080           Host 4000 -> container 8080
  incs -n your-container -b 10.0.0.5 4000   Bind to a specific IP (e.g. Tailscale)
  incs -n your-container -H host.ts.net 4000 Bind to the IP resolved from an FQDN
  incs -n your-container -l                  List proxies on your-container
  incs -e your-container OPENAI_API_KEY      Set env var in your-container (prompts silently)
  incs -d your-container                     Delete your-container
  incs -k your-container                     Stop your-container
  incs -ka                       Stop all agent-incus containers
  incs -u your-container                     Update packages in your-container
  incs -ua                       Update all agent-incus containers
  incs cron install              Install 7pm daily update cron
  incs cron install 3            Install 3am daily update cron
EOF
  exit 0
}

is_debian() {
  local container="$1"
  incus exec "$container" -- sh -c 'test -f /etc/debian_version' </dev/null &>/dev/null
}

ensure_log_dir() {
  mkdir -p "$INCS_LOG_DIR"
}

write_status() {
  local status="$1"
  local details="${2:-}"
  mkdir -p "$(dirname "$INCS_STATUS_FILE")"
  cat > "$INCS_STATUS_FILE" <<STATUSEOF
status=$status
date=$(date '+%Y-%m-%d %H:%M')
details=$details
STATUSEOF
}

cmd_update() {
  local container="$1"
  local logfile="${2:-}"
  if [[ -n "$logfile" ]]; then
    echo "=== $container $(date) ===" >> "$logfile"
    incus exec "$container" -- sh -c '
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -qq && apt-get upgrade -y
    ' </dev/null >> "$logfile" 2>&1 || {
      echo "  ⚠️  Failed to update $container" >&2
      return 1
    }
  else
    incus exec "$container" -- sh -c '
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -qq && apt-get upgrade -y
    ' </dev/null || {
      echo "  ⚠️  Failed to update $container" >&2
      return 1
    }
  fi
  log "Updated $container"
}

cmd_update_all() {
  local containers
  containers=$(incus list user.managed-by=agent-incus --format csv --columns ns 2>/dev/null) || {
    error "Failed to list containers"
  }
  if [[ -z "$containers" ]]; then
    echo "No incus-init managed containers found"
    return
  fi

  ensure_log_dir
  local failed=()
  local logfile="$INCS_LOG_DIR/update-$(date +%Y%m%d-%H%M%S).log"

  while IFS=, read -r name status; do
    local was_running=0
    if [[ "$status" == "RUNNING" ]]; then
      was_running=1
    else
      log "Starting $name..."
      incus start "$name"
      # Wait for container to be ready
      local attempts=0
      while true; do
        if timeout 5 incus exec "$name" -- true </dev/null &>/dev/null; then
          break
        fi
        sleep 1
        attempts=$((attempts + 1))
        if [[ $attempts -ge 30 ]]; then
          echo "  ⚠️  Timed out waiting for $name" >&2
          failed+=("$name")
          continue 2
        fi
      done
    fi
    if ! is_debian "$name"; then
      echo "  ⚠️  WARNING: $name is tagged as agent-incus but is not Debian/Ubuntu — skipping update"
      [[ "$was_running" == "0" ]] && incus stop "$name"
      continue
    fi
    log "Updating $name..."
    if ! cmd_update "$name" "$logfile"; then
      failed+=("$name")
    fi
    # Only stop containers that were stopped before we started
    if [[ "$was_running" == "0" ]]; then
      log "Stopping $name..."
      incus stop "$name"
    fi
  done < <(echo "$containers")

  echo ""
  if [[ ${#failed[@]} -gt 0 ]]; then
    echo "⚠️  Failed: ${failed[*]}"
    echo "   See $logfile for details"
    write_status "failed" "${failed[*]}"
  else
    rm -f "$logfile"
    log "All containers updated successfully"
    write_status "ok"
  fi
}

# ---------------------------------------------------------------------------
# Set an environment variable in a container without echoing it to the screen.
# Writes both `incus config set environment.VAR=...` (for incus exec sessions)
# and `export VAR=...` into ~/.zshenv (for `su -` login shells). Any prior
# entry for the same var in ~/.zshenv is removed first so re-setting replaces.
# ---------------------------------------------------------------------------
cmd_set_env() {
  local container="${1:-}"
  local var_name="${2:-}"

  [[ -z "$container" || -z "$var_name" ]] && \
    error "Usage: incs -e <container> <VAR_NAME>"

  [[ "$var_name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || \
    error "Invalid variable name: $var_name"

  incus info "$container" &>/dev/null || \
    error "Container not found: $container"

  local status
  status=$(incus list "^${container}$" --format csv --columns s 2>/dev/null)
  if [[ "$status" != "RUNNING" ]]; then
    log "Starting $container..."
    incus start "$container"
    local attempts=0
    while ! timeout 5 incus exec "$container" -- true </dev/null &>/dev/null; do
      sleep 1
      attempts=$((attempts + 1))
      if [[ $attempts -ge 30 ]]; then
        error "Timed out waiting for $container"
      fi
    done
  fi

  local value
  read -rsp "Enter value for $var_name (input hidden, paste ok): " value
  echo ""
  [[ -z "$value" ]] && error "Value required"

  incus config set "$container" "environment.$var_name=$value"

  local host_user export_line
  host_user="$(id -un)"
  printf -v export_line 'export %s=%q\n' "$var_name" "$value"

  printf '%s' "$export_line" | incus exec "$container" -- \
    su - "$host_user" -s /bin/sh -c '
      touch ~/.zshenv
      sed -i "/^export '"$var_name"'=/d" ~/.zshenv
      cat >> ~/.zshenv
    '

  log "Set $var_name in $container"
}

# ---------------------------------------------------------------------------
# Cron management
# ---------------------------------------------------------------------------
CRON_TAG="# incs-update-all"

cmd_cron() {
  local action="${1:-}"
  case "$action" in
    install)
      local hour="${2:-19}"
      # Validate hour
      if ! [[ "$hour" =~ ^[0-9]+$ ]] || [[ "$hour" -gt 23 ]]; then
        error "Invalid hour: $hour (must be 0-23)"
      fi
      ensure_log_dir
      local incs_path
      incs_path="$(realpath "$0")"
      local cron_line="0 $hour * * * $incs_path -ua >> $INCS_LOG_DIR/cron.log 2>&1 $CRON_TAG"
      # Remove existing entry, add new one
      (crontab -l 2>/dev/null | grep -v "$CRON_TAG"; echo "$cron_line") | crontab -
      log "Installed cron: daily at $(printf '%02d' "$hour"):00"
      echo "  Logs: $INCS_LOG_DIR/cron.log"
      ;;
    remove)
      crontab -l 2>/dev/null | grep -v "$CRON_TAG" | crontab -
      log "Removed incs update cron"
      ;;
    status)
      local entry
      entry=$(crontab -l 2>/dev/null | grep "$CRON_TAG" || true)
      if [[ -n "$entry" ]]; then
        echo "Active: $entry"
      else
        echo "No incs update cron installed"
      fi
      ;;
    *)
      error "Usage: incs cron {install [HOUR]|remove|status}"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Login notification — source this snippet from .zshrc/.bashrc
# ---------------------------------------------------------------------------
cmd_notify_snippet() {
  cat <<'SNIPPET'
# incs update notification — add to ~/.zshrc or ~/.bashrc
if [[ -f "$HOME/.local/state/incs/last-update" ]]; then
  _incs_status=$(grep '^status=' "$HOME/.local/state/incs/last-update" | cut -d= -f2)
  _incs_date=$(grep '^date=' "$HOME/.local/state/incs/last-update" | cut -d= -f2-)
  _incs_details=$(grep '^details=' "$HOME/.local/state/incs/last-update" | cut -d= -f2-)
  if [[ "$_incs_status" == "failed" ]]; then
    echo -e "\033[1;33m⚠️  incs update failed ($_incs_date): $_incs_details\033[0m"
    echo "   Run 'ls ~/.local/state/incs/logs/' to see logs"
  fi
  unset _incs_status _incs_date _incs_details
fi
SNIPPET
}

[[ $# -eq 0 ]] && usage

case "$1" in
  -h|--help|help)
    usage
    ;;
  -s|shell)
    shift
    exec "$SCRIPT_DIR/incus.shell" "$@"
    ;;
  -i|init)
    shift
    exec "$SCRIPT_DIR/incus.init" "$@"
    ;;
  -n|net)
    shift
    exec "$SCRIPT_DIR/incus.network" "$@"
    ;;
  -e|env)
    shift
    cmd_set_env "$@"
    ;;
  -d|delete)
    shift
    [[ $# -lt 1 ]] && error "Usage: incs delete <container>"
    incus delete --force "$1"
    log "Deleted $1"
    ;;
  -k|kill)
    shift
    [[ $# -lt 1 ]] && error "Usage: incs kill <container>"
    incus stop "$1"
    log "Stopped $1"
    ;;
  -ka|kill-all)
    containers=$(incus list user.managed-by=agent-incus status=running --format csv --columns n 2>/dev/null)
    if [[ -z "$containers" ]]; then
      echo "No running agent-incus containers"
    else
      for c in $containers; do
        incus stop "$c"
        log "Stopped $c"
      done
    fi
    ;;
  -u|update)
    shift
    [[ $# -lt 1 ]] && error "Usage: incs update <container>"
    cmd_update "$1"
    ;;
  -ua|update-all)
    cmd_update_all
    ;;
  cron)
    shift
    cmd_cron "$@"
    ;;
  new-plugin)
    shift
    exec "$SCRIPT_DIR/incs.new-plugin" "$@"
    ;;
  notify-snippet)
    cmd_notify_snippet
    ;;
  -*)
    error "Unknown command: $1 (try incs -h)"
    ;;
  *)
    # Default: shell into container
    exec "$SCRIPT_DIR/incus.shell" "$@"
    ;;
esac
